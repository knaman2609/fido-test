{
  "name": "blocknote-editor",
  "version": "1.0.0",
  "description": "A BlockNote rich text editor with localStorage persistence",
  "type": "module",
  "scripts": {
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "build": "npm i && npm run lint && tsc",
    "watch": "tsc --watch",
    "serve": "serve . -p 3000",
    "start": "npm run build && npm run serve",
    "clean": "node scripts/clean.js"
  },
  "keywords": [
    "blocknote",
    "editor",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@blocknote/core": "^0.15.0",
    "@blocknote/mantine": "^0.15.0",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.3",
    "serve": "^14.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.0"
  }
}