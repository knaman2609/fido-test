{
  "name": "todo-app",
  "version": "1.0.0",
  "description": "A simple TypeScript Todo App",
  "type": "module",
  "scripts": {
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "build": "tsc",
    "watch": "tsc --watch",
    "serve": "serve . -p 3000",
    "start": "npm run build && npm run serve",
    "clean": "node scripts/clean.js"
  },
  "keywords": [
    "todo",
    "typescript",
    "app"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@blocknote/core": "^0.25.0",
    "@blocknote/mantine": "^0.25.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "serve": "^14.0.0",
    "typescript": "^5.9.3"
  }
}
