{
  "name": "todo-app",
  "version": "1.0.0",
  "description": "A simple TypeScript Todo App",
  "type": "module",
  "scripts": {
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "build": "eslint 'src/**/*.ts' && tsc",
    "watch": "tsc --watch",
    "serve": "serve . -p 3000",
    "start": "npm run build && npm run serve",
    "clean": "node scripts/clean.js"
  },
  "keywords": [
    "todo",
    "typescript",
    "app"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "eslint": "8.57.0",
    "serve": "14.2.4",
    "typescript": "5.7.3"
  },
  "dependencies": {
    "@blocknote/core": "0.47.1",
    "@blocknote/mantine": "0.47.1"
  }
}
