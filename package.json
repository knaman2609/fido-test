{
  "name": "blocknote-editor",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "npm install --include=dev && npm run lint && tsc",
    "watch": "tsc --watch",
    "serve": "serve -p 3000",
    "start": "npm run build && npm run serve",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@blocknote/core": "^0.15.0",
    "@blocknote/mantine": "^0.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "serve": "^14.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.57.0"
  }
}
